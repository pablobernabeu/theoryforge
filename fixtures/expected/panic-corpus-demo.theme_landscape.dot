digraph theme_landscape {
  rankdir=LR;
  node [shape=box];
  "theme_1" [label="theme_1: appraisal, catastrophic misinterpretation (covered)"];
  "theme_2" [label="theme_2: arousal, interoception (crowded)"];
  "theme_3" [label="theme_3: avoidance, exposure (covered)"];
  "theme_4" [label="theme_4: genetics, heritability (under_theorized)"];
  "alt_cognitive" [label="alt_cognitive", shape=ellipse];
  "alt_biological" [label="alt_biological", shape=ellipse];
  "focal" [label="focal", shape=ellipse, style=bold];
  "alt_cognitive" -> "theme_1";
  "alt_biological" -> "theme_2";
  "focal" -> "theme_2";
  "focal" -> "theme_3";
}
