# lavaan model generated by theoryforge for mediation-demo
# Measurement model
m_stressor =~ exam_proximity_in_days + stakes_rating
m_appraisal =~ appraisal_questionnaire
m_anxiety =~ state_anxiety_inventory + heart_rate_before_the_exam
# Structural model
m_appraisal ~ m_stressor
m_anxiety ~ m_appraisal
